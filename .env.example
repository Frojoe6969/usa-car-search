# Copy this file to .env and fill in your values.
# Then uncomment the dotenv block at the top of car-search.py,
# OR export these variables in your shell before running.

# ── Vehicle to search for ─────────────────────────────────────────────────────
SEARCH_MAKE=Honda
SEARCH_MODEL=Civic
# Used for free-text searches (Craigslist, Facebook, eBay)
SEARCH_KEYWORDS=honda civic

# ── Search location ───────────────────────────────────────────────────────────
SEARCH_ZIP=10001          # Your ZIP code
SEARCH_RADIUS=150         # Miles from ZIP

# ── Vehicle filters ───────────────────────────────────────────────────────────
MIN_YEAR=2019
MAX_YEAR=2021
MAX_MILES=65000
MIN_PRICE=15000
MAX_PRICE=40000
ALLOWED_COLORS=black,gray,grey,charcoal,dark,obsidian,magnetic,graphite
ALLOWED_TRIMS=              # Leave blank for all trims; example: limited,sti

# ── Craigslist regions ────────────────────────────────────────────────────────
# Comma-separated subdomain slugs from https://www.craigslist.org/about/sites
CL_REGIONS=newyork,boston,philadelphia

# ── CarGurus ──────────────────────────────────────────────────────────────────
# Go to cargurus.com → search with your filters → copy the URL from your browser
CARGURUS_URL=
CARGURUS_URL_2=    # optional second search (e.g. a variant/trim)

# ── AutoTrader ────────────────────────────────────────────────────────────────
# Go to autotrader.com → search with your filters → copy the URL from your browser
AUTOTRADER_URL=

# ── Cars.com ──────────────────────────────────────────────────────────────────
# Go to cars.com → search with your filters → copy the URL from your browser
CARSDOTCOM_URL=

# ── Facebook Marketplace ──────────────────────────────────────────────────────
# City slug from facebook.com/marketplace/<city>/search
FB_CITY=newyork
FB_SESSION_FILE=./fb-session.json

# ── Telegram notifications ────────────────────────────────────────────────────
TG_BOT_TOKEN=             # From @BotFather
TG_CHAT_ID=               # Chat ID (numeric) or @username for public channels
TG_TOPIC_ID=              # Optional: forum topic/thread ID

# ── API keys ──────────────────────────────────────────────────────────────────
AUTODEV_API_KEY=          # Free at https://auto.dev
EBAY_TOKEN_FILE=./ebay-token.txt          # eBay User OAuth access token (see README)
EBAY_REFRESH_TOKEN_FILE=./ebay-refresh-token.txt  # eBay refresh token for auto-renewal
EBAY_CLIENT_ID=           # From developer.ebay.com → Your App
EBAY_CLIENT_SECRET=       # From developer.ebay.com → Your App
EBAY_RUNAME=              # RuName from eBay developer portal

# ── AutoTrader Chrome CDP (optional, improves results) ────────────────────────
# WSL2: run `ip route show default | awk '{print $3}'` to find this IP
CHROME_CDP_HOST=
CHROME_CDP_PORT=9222

# ── Enable/disable individual sources ─────────────────────────────────────────
ENABLE_CARGURUS=true      # Requires CARGURUS_URL
ENABLE_CRAIGSLIST=true
ENABLE_CARSDOTCOM=true    # Requires CARSDOTCOM_URL
ENABLE_AUTOTRADER=true    # Requires AUTOTRADER_URL
ENABLE_FACEBOOK=true      # Requires fb-session.json (run fb-auth-setup.py)
ENABLE_EBAY=true          # Uses API if ebay-token.txt exists, else scrapes
ENABLE_AUTODEV=true       # Requires AUTODEV_API_KEY